<Window x:Class="Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Editor"
        mc:Ignorable="d"
      xmlns:i="clr-namespace:Editor.View"
        xmlns:m="clr-namespace:ViewPortLib;assembly=ViewPortLib"
        xmlns:view="clr-namespace:Editor.View"
      xmlns:control="clr-namespace:Editor.Control"
        Title="MainWindow" Height="700" Width="800"  Visibility="Visible" WindowState="Maximized">
    <Window.Resources>
   
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Command="{Binding SaveCommand}" Gesture="Ctrl+S"/>
    </Window.InputBindings>
    <Grid i:ThemeProps.Background="{ DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <!--<StackPanel Orientation="Horizontal">
            <Button Content="添加组件" Visibility="Visible" Command="{Binding InitRenderCommand}" Background="Green" />
        </StackPanel>-->
        <Menu Grid.Row="0" Background="Transparent">
            <MenuItem Header="文件">
                <MenuItem Header="导入"/>
            </MenuItem>
            <MenuItem Header="场景">
                <MenuItem Header="预设场景" Command="{Binding OpenReadySceneCommand}"/>
                <MenuItem Header="添加场景" Command="{Binding AddSceneNodeCommand}"/>
            </MenuItem>
            <MenuItem Header="工具">
                <MenuItem Header="显示主题颜色" Command="{Binding ShowColorCommand}"/>
                <Separator/>
                <MenuItem Header="主题">
                    <MenuItem Header="深色" Command="{Binding SwitchThemeCommand}" CommandParameter="Dark"/>
                    <MenuItem Header="亮蓝色" Command="{Binding SwitchThemeCommand}" CommandParameter="LightBlue"/>
                    <MenuItem Header="蓝色" Command="{Binding SwitchThemeCommand}" CommandParameter="Blue"/>
                </MenuItem>
                
            </MenuItem>

        </Menu>
        <view:DockMainView Grid.Row="1"/>
     
    </Grid>
  
</Window>

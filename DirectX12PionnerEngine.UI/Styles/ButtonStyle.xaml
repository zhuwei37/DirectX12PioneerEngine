<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:i="clr-namespace:DirectX12PionnerEngine.UI.Helpers"
                    xmlns:rs="clr-namespace:DirectX12PionnerEngine.UI.Resources">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/DirectX12PionnerEngine.UI;component/Templates/ButtonTemplate.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style TargetType="Button">
        <Setter Property="i:ButtonHelper.ClickBackground" Value="{DynamicResource PrimaryPressedBrush}"/>
        <Setter Property="i:ButtonHelper.HoverBackground" Value="{DynamicResource PrimaryHoverBrush}"/>
        <Setter Property="i:ElementStateManager.Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="i:ElementStateManager.BorderCornerRadius" Value="3"/>
        <Setter Property="i:ElementStateManager.BorderThickness" Value="0.5"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template" Value="{StaticResource {x:Static rs:TemplateKeys.ButtonTemplate}}"/>
       
    </Style>
</ResourceDictionary>
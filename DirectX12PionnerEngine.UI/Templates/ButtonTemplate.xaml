<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:rs="clr-namespace:DirectX12PionnerEngine.UI.Resources"
                    xmlns:i="clr-namespace:DirectX12PionnerEngine.UI.Helpers">

    <ControlTemplate x:Key="{x:Static rs:TemplateKeys.ButtonTemplate}" TargetType="Button" >
        <Border x:Name="Bor"
             BorderThickness="{Binding Path=(i:ElementStateManager.BorderThickness),RelativeSource={RelativeSource TemplatedParent}}"
                CornerRadius="{Binding Path=(i:ElementStateManager.BorderCornerRadius),RelativeSource={RelativeSource TemplatedParent}}"
                Background="{Binding Path=(i:ElementStateManager.Background),RelativeSource={RelativeSource TemplatedParent}}"
            >
            <Border>
            <ContentPresenter Focusable="False" 
                RecognizesAccessKey="True"
                              HorizontalAlignment="{Binding RelativeSource={RelativeSource TemplatedParent},Path=HorizontalContentAlignment}"
                              VerticalAlignment="{Binding RelativeSource={RelativeSource TemplatedParent},Path=VerticalContentAlignment}"/>
            </Border>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" TargetName="Bor" 
                        Value="{Binding Path=(i:ButtonHelper.HoverBackground),RelativeSource={RelativeSource TemplatedParent}}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" TargetName="Bor" 
                        Value="{Binding Path=(i:ButtonHelper.ClickBackground),RelativeSource={RelativeSource TemplatedParent}}"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
          
        </ControlTemplate.Triggers>
    </ControlTemplate>
</ResourceDictionary>